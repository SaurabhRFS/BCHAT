<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1976D2">

    <!-- TOP SECTION -->
    <LinearLayout
        android:id="@+id/topSection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/sosCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@android:drawable/ic_dialog_info"
            android:tint="#fffff"
            android:padding="8dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Emergency System Ready"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <com.google.android.material.button.MaterialButton
            app:icon="@android:drawable/stat_notify_sync"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Connect to Mesh Network"
            android:textSize="15sp"
            android:textAllCaps="false"
            app:backgroundTint="#0D47A1"
            android:textColor="#FFFFFF"
            app:cornerRadius="50dp"
            app:icon="@android:drawable/stat_sys_upload"
            app:iconTint="#FFFFFF"
            app:iconGravity="textStart"
            app:iconPadding="10dp" />
    </LinearLayout>

    <!-- SOS CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/sosCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/topSection"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- TITLE -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Send Emergency Alert"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginBottom="16dp" />

                <!-- RED -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSosRed"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:text="RED - Critical Emergency"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="#D32F2F"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="50dp"
                    app:icon="@android:drawable/ic_delete"
                    app:iconTint="#FFFFFF"
                    app:iconGravity="textStart"
                    android:layout_marginBottom="12dp" />

                <!-- ORANGE -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSosOrange"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:text="ORANGE - Urgent Help"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="#F57C00"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="50dp"
                    app:icon="@android:drawable/ic_dialog_alert"
                    app:iconTint="#FFFFFF"
                    app:iconGravity="textStart"
                    android:layout_marginBottom="12dp" />

                <!-- YELLOW -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSosYellow"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="YELLOW - FOOD CRISIS"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="#FBC02D"
                    android:textColor="#212121"
                    app:cornerRadius="50dp"
                    app:icon="@android:drawable/ic_menu_info_details"
                    app:iconTint="#212121"
                    app:iconGravity="textStart"
                    android:layout_marginBottom="20dp" />

                <!-- INFO SECTION -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GUIDELINES"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• RED: Use in life-threatening situations (accident, severe injury, attack).\n• ORANGE: Use when immediate help is needed but not critical.\n• YELLOW: Use for food crisis.\n\nSYSTEM INFO:\n• Your GPS location is automatically shared.\n• Alerts are broadcast to nearby mesh devices.\n• Data is uploaded to cloud when internet is available.\n\nIMPORTANT:\n• Stay calm and ensure safety before sending SOS.\n• Use RED only in real emergencies to avoid false alerts."
                    android:textColor="#616161"
                    android:textSize="13sp"
                    android:lineSpacingExtra="5dp" />

            </LinearLayout>

        </ScrollView>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>