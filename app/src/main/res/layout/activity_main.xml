<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#0D0D0D">

    <!-- STATUS -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="System Ready"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- CONNECT -->
    <Button
        android:id="@+id/btnConnect"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="CONNECT TO MESH"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:backgroundTint="#2962FF"
        android:textColor="#FFFFFF"
        android:elevation="6dp"
        android:layout_marginBottom="20dp" />

    <!-- SOS CARD -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        card_view:cardCornerRadius="20dp"
        card_view:cardElevation="8dp"
        android:backgroundTint="#1A1A1A">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- RED (TOP PRIORITY) -->
            <Button
                android:id="@+id/btnSosRed"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:text="🚨 RED SOS"
                android:textSize="20sp"
                android:textStyle="bold"
                android:backgroundTint="#D50000"
                android:textColor="#FFFFFF"
                android:elevation="8dp"
                android:layout_marginBottom="12dp" />

            <!-- 🟠 ORANGE -->
            <Button
                android:id="@+id/btnSosOrange"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:text="⚠️ ORANGE SOS"
                android:textSize="18sp"
                android:textStyle="bold"
                android:backgroundTint="#FF6D00"
                android:textColor="#FFFFFF"
                android:elevation="6dp"
                android:layout_marginBottom="12dp" />

            <!-- 🟡 YELLOW -->
            <Button
                android:id="@+id/btnSosYellow"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:text="🟡 YELLOW SOS"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#FFD600"
                android:textColor="#000000"
                android:elevation="4dp"
                android:layout_marginBottom="16dp" />

            <!-- 📘 INFO TEXT -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔴 RED: Use for life-threatening emergencies.\n🟠 ORANGE: Use for urgent but not critical situations.\n🟡 YELLOW: Use for low-risk situations."
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>